APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ========== PRODUCTION: set these on the server (backend/.env) ==========
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://evelinecosmetics.ma
# APP_FORCE_HTTPS=true
# CORS_ORIGINS=https://evelinecosmetics.ma,https://www.evelinecosmetics.ma
# SANCTUM_EXPIRATION=1440
# SESSION_SECURE_COOKIE=true
# ========================================================================

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
# In production set to true so cookies are only sent over HTTPS
SESSION_SECURE_COOKIE=false

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# CMI Payment Gateway (Morocco) – replace placeholders when credentials are provided
CMI_MERCHANT_ID=YOUR_CMI_MERCHANT_ID
CMI_STORE_KEY=YOUR_CMI_SECRET_KEY
CMI_TERMINAL_ID=YOUR_TERMINAL_ID
CMI_MODE=sandbox
CMI_CURRENCY=MAD
# Optional: override callback URL (default: app URL + /api/payment/callback)
# CMI_CALLBACK_URL=https://yourdomain.com/api/payment/callback
FRONTEND_URL=http://localhost:3000

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
