# CMI Payment Gateway Configuration
# Centre Monétique Interbancaire - Maroc

CMI_ENABLED=true
CMI_MODE=sandbox # sandbox or production

# Credentials CMI
CMI_MERCHANT_ID=your_merchant_id
CMI_MERCHANT_USERNAME=your_username
CMI_MERCHANT_PASSWORD=your_password

# Currency
CMI_CURRENCY=MAD

# API Timeout
CMI_TIMEOUT=30

# Logging
CMI_LOG=true

# Webhook Configuration
CMI_WEBHOOK_SECRET=your_webhook_secret
CMI_WEBHOOK_ENABLED=true

# Security
CMI_VERIFY_SSL=true
CMI_ENCRYPT_RESPONSES=true

# Features
CMI_3D_SECURE=true
CMI_RECURRING=false
CMI_TOKENIZATION=true

# Frontend URLs
FRONTEND_URL=http://localhost:3000

